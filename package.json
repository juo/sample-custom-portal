{
  "name": "@juo/blocks-beauty-theme",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5180",
    "typecheck": "tsc --noEmit --pretty false -p tsconfig.json && tsc --noEmit --pretty false -p tsconfig.node.json",
    "lint": "pnpm run typecheck && pnpm run format:check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm run typecheck",
    "build": "pnpm run typecheck && vite build",
    "preview": "vite preview",
    "ci": "pnpm run lint && pnpm run test && pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "10.4.20",
    "json-schema-to-ts": "3.1.1",
    "postcss": "8.4.33",
    "prettier": "^3.6.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.7.3",
    "vite": "5.4.21"
  },
  "dependencies": {
    "@juo/blocks": "1.1.0-alpha.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.5.3"
  }
}
