# Use mocked adapters for a zero-backend local demo.
# Set to "false" to use real API adapters.
VITE_MOCK_MODE=true

# Base URL of your backend service when VITE_MOCK_MODE=false.
# Example: http://localhost:3000
VITE_API_URL=https://api.juo.io

# Shopify domain used by auth and API headers.
# Example: beauty-box.myshopify.com
VITE_SHOP_DOMAIN=beauty-box.myshopify.com

# Extension blocks are versioned separately from @juo/blocks core.
# Optional version override used by the default extensions URL:
# https://cdn.juo.io/web/blocks/juo/<version>/extensions.js
VITE_BLOCKS_EXTENSIONS_VERSION=1.2.0

# Optional full URL override (takes precedence over VITE_BLOCKS_EXTENSIONS_VERSION).
# VITE_BLOCKS_EXTENSIONS_URL=https://cdn.juo.io/web/blocks/juo/1.2.0/extensions.js
